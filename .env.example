# Kraken API credentials
NITRO_KRAKEN_API_KEY=
NITRO_KRAKEN_PRIVATE_KEY=

# API authentication (optional, leave empty to disable)
NITRO_API_TOKEN=

# Grid trading parameters
NITRO_GRID_LOWER_PRICE=80000
NITRO_GRID_UPPER_PRICE=100000
NITRO_GRID_LEVELS=10
NITRO_ORDER_SIZE_USDC=50

# Sandbox mode (true = validate orders on Kraken but don't execute)
NITRO_SANDBOX_MODE=true

# Post-only orders (true = maker fees only, rejects taker orders)
NITRO_POST_ONLY=true

# Sentry error tracking (optional, leave empty to disable)
NITRO_SENTRY_DSN=
